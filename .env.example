# ----- 通义千问 API 配置（必填） -----
QWEN_API_KEY=这里填你的通义千问API Key，例如 sk-xxxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ----- 服务器配置 -----
PORT=3000
